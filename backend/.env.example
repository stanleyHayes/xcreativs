# Database
DB_URL=postgres://xcreatives:xcreatives_dev@localhost:5432/xcreatives?sslmode=disable

# Server
PORT=8081
ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# JWT (generate strong secrets for production)
JWT_SECRET=your-jwt-secret-min-32-chars-long
JWT_REFRESH_SECRET=your-jwt-refresh-secret-min-32-chars-long

# Redis (optional - for session store in production)
REDIS_URL=localhost:6379

# Email (optional)
RESEND_API_KEY=

# Media / file uploads — Cloudinary (optional; /uploads returns 501 until set,
# and generated TTS audio is uploaded here when configured)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Public frontend base URL (used for SSO redirects, invoice payment links, RSS feeds)
BASE_URL=http://localhost:3001

# OAuth SSO (optional — endpoints return 501 until configured)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=

# Payment gateways (optional — invoices fall back to an internal payment link until set)
PAYSTACK_SECRET_KEY=
STRIPE_SECRET_KEY=

# Enterprise SSO via generic OIDC (Okta / Azure AD / Auth0 / Keycloak). Endpoint
# /auth/oauth/oidc/login returns 501 until configured.
OIDC_AUTH_URL=
OIDC_TOKEN_URL=
OIDC_USERINFO_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_SCOPE=openid email profile

# Mandatory MFA enforcement for all authenticated users (spec §4.6)
MFA_REQUIRED=false

# SMS / WhatsApp notifications via Twilio (optional — channels are no-ops until set)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TWILIO_WHATSAPP_FROM=

# AI Concierge generative layer (optional — falls back to extractive retrieval until set)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Audio-brief TTS (optional, OpenAI-compatible /audio/speech — returns 501 until set)
TTS_API_URL=
TTS_API_KEY=
TTS_MODEL=tts-1
TTS_VOICE=alloy
